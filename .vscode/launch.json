{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: 当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
        },
        {
            "name": "Python: 测试提取器",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/test_extractor.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "TEST_MODE": "True"
            },
        },
        {
            "name": "Python: 运行所有测试",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "TEST_MODE": "True"
            },
        },
        {
            "name": "Python: 模块",
            "type": "debugpy",
            "request": "launch",
            "module": "src.extract_dialogue",
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "data/test.txt",
                "--output", "output.jsonl",
                "--threads", "2"
            ]
        },
        {
            "name": "Python: 模块 (单线程)",
            "type": "debugpy",
            "request": "launch",
            "module": "src.extract_dialogue",
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "data/test.txt",
                "--output", "output.jsonl",
                "--no-concurrent"
            ]
        }
    ]
}
